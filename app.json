{
  "expo": {
    "name": "AYONIME",
    "slug": "ayonime",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "android": {
      "package": "com.ayomikun.ayonime",
      "permissions": ["INTERNET", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0f"
      }
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-video",
      "expo-media-library",
      "react-native-svg"
    ],
    "scheme": "ayonime",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "11309220-3a9e-43ba-a74f-a3e18facf2f3" }
    }
  }
}
